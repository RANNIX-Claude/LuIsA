# Node modules (instalar con npm install)
node_modules/
.netlify/functions/node_modules/
package-lock.json
yarn.lock

# Netlify
.netlify/
.env
.env.local
.env.*.local

# IDE
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temporal
*.tmp
*.temp
tmp/
temp/

# Build artifacts
dist/
build/
.cache/

# OS
.DS_Store
Thumbs.db

# Backups
*.backup
*.bak
*.old

# Secrets (Never commit these!)
.env.production
.env.production.local
secrets/
credentials.json
api-keys.json

# Testing
.coverage
coverage/
.nyc_output

# Optional npm cache
.npm

# Output directory
out/
.claude/settings.local.json
